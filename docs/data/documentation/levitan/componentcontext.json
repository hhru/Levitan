":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@dynamicMemberLookup"},{"kind":"text","text":" "},{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ComponentContext"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Является универсальным окружением для UIKit и SwiftUI компонентов"},{"type":"text","text":" "},{"type":"text","text":"и предоставляет механизм переопределения его переменных."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Содержит изначальное окружение и отдельно переопределения его значений."},{"type":"text","text":" "},{"type":"text","text":"Такая структура позволяет наследовать полноценное окружение из SwiftUI,"},{"type":"text","text":" "},{"type":"text","text":"заменяя в нем только переопределенные значения."}]},{"text":"Начальный контекст","level":1,"anchor":"%D0%9D%D0%B0%D1%87%D0%B0%D0%BB%D1%8C%D0%BD%D1%8B%D0%B9-%D0%BA%D0%BE%D0%BD%D1%82%D0%B5%D0%BA%D1%81%D1%82","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Если в прокте корневым является SwiftUI-компонент,"},{"type":"text","text":" "},{"type":"text","text":"то нет необходимости создавать начальный контекст самостоятельно."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"В случае корневого UIKit-компонента контекст создается в нем через static-свойство "},{"type":"codeVoice","code":"default"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"В этом случае некоторые переменные получают значения из UIKit-характеристик "},{"type":"codeVoice","code":"UITraitCollection"},{"type":"text","text":"."}]},{"text":"Использование в SwiftUI","level":1,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Для SwiftUI контекст компонента трансформируется в обычное окружение,"},{"type":"text","text":" "},{"type":"text","text":"и его использование ничем не отличается от использования в обычных UI-представлениях, например:"}]},{"syntax":"swift","type":"codeListing","code":["struct Foo: View {","","    @Environment(\\.isEnabled)","    private var isEnabled","","    var body: some View {","        Text(isEnabled ? \"Enabled\" : \"Disabled\")","            .dynamicTypeSize(.small) \/\/ переопределение переменной окружения","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Как видно из примера, переопределение происходит точно так же, как и с обычным UI-представлением."},{"type":"text","text":" "},{"type":"text","text":"Добавление новых переменных также аналогично стандартному механизму в SwiftUI."}]},{"text":"Использование в UIKit","level":1,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"В случае UIKit-компонентов контекст используется напрямую,"},{"type":"text","text":" "},{"type":"text","text":"UI-представление компонента получает его в методе обновления "},{"type":"codeVoice","code":"update(with:context:)"},{"type":"text","text":", например:"}]},{"syntax":"swift","type":"codeListing","code":["extension FooView: FallbackComponentView {","","    func update(with content: Foo, context: ComponentContext) {","        label.text = context.isEnabled ? \"Enabled\" : \"Disabled\"","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Доступны все переменные окружения из SwiftUI, некоторые из них сами трансформируются в UIKit-характеристики,","type":"text"},{"text":" ","type":"text"},{"text":"например ","type":"text"},{"type":"codeVoice","code":"dynamicTypeSize"},{"text":" в ","type":"text"},{"type":"codeVoice","code":"UITraitCollection.pr