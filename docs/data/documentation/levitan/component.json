{"sections":[],"hierarchy":{"paths":[["doc:\/\/ru.hh.Levitan\/documentation\/Levitan"]]},"abstract":[{"text":"Общий протокол для всех UI-компонентов.","type":"text"}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/ru.hh.Levitan\/SQ","doc:\/\/ru.hh.Levitan\/7SwiftUI4ViewP"],"title":"Inherits From"},{"kind":"relationships","type":"inheritedBy","identifiers":["doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackComponent","doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackManualComponent","doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/ManualComponent"],"title":"Inherited By"},{"kind":"relationships","type":"conformingTypes","identifiers":["doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/AnyComponent","doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/AnyManualComponent","doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/SwiftUICore\/ModifiedContent","doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/Text"],"title":"Conforming Types"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"Component","kind":"identifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","text":"Equatable","preciseIdentifier":"s:SQ"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Протокол "},{"code":"Component","type":"codeVoice"},{"text":" максимально приспособлен для реализации SwiftUI-компонентов,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"достаточно реализовать стандартное свойство "},{"type":"codeVoice","code":"body"},{"type":"text","text":" и метод "},{"type":"codeVoice","code":"sizing(fitting:context:)"},{"type":"text","text":", например:"}]},{"type":"codeListing","code":["struct Foo: Component {","","    let text: String","","    var body: some View {","        Text(text)","    }","","    func sizing(fitting size: CGSize, context: ComponentContext) -> ComponentSizing {","        ComponentSizing(width: .fill, height: .hug)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Для удобства реализации UIKit-компонентов используется протокол ","type":"text"},{"type":"codeVoice","code":"FallbackComponent"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"который так же соответствует протоколу ","type":"text"},{"type":"codeVoice","code":"Component"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"но предоставляет другую реализацию по умолчанию для некоторых его полей."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Любой UI-компонент, соответствующий этому протоколу "},{"type":"codeVoice","code":"Component"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"можно использовать и в SwiftUI, и UIKit."}]},{"text":"Использование в SwiftUI","type":"heading","level":1,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-SwiftUI"},{"inlineContent":[{"type":"text","text":"Использование компонента в SwiftUI ничем не отличается от использования обычного UI-представления, например:"}],"type":"paragraph"},{"type":"codeListing","code":["struct Bar: View {","","    var body: some View {","        Foo(text: \"Hello world\")","    }","}"],"syntax":"swift"},{"text":"Использование в UIKit","type":"heading","level":1,"anchor":"%D0%98%D1%81%D0%BF%D0%BE%D0%BB%D1%8C%D0%B7%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D0%B5-%D0%B2-UIKit"},{"inlineContent":[{"type":"text","text":"В UIKit данные и UI-представление разделены, при этом сам компонент является данными."},{"type":"text","text":" "},{"type":"text","text":"UI-представление создается под ассоциированным типом "},{"type":"codeVoice","code":"UIView"},{"type":"text","text":" компонента,"},{"type":"text","text":" "},{"type":"text","text":"а данные обновляются его методом "},{"type":"codeVoice","code":"update(with:context:)"},{"type":"text","text":", например:"}],"type":"paragraph"},{"type":"codeListing","code":["class BarView: UIView {","","    let fooView = Foo.UIView()","","    override init(frame: CGRect = .zero) {","        super.init(frame: frame)","","        setupFooView()","    }","","    func setupBarView() {","        addSubview(fooView)","","        fooView.snp.makeConstraints { make in","            make.edges.equalToSuperview()","        }","","        \/\/ Обновление компонента","        fooView.update(","            with: Foo(text: \"Hello world\"),","            context: .default","        )","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"В этом примере UI-представление компонента обновляется, используя контекст по умолчанию,","type":"text"},{"text":" ","type":"text"},{"text":"но в реальном приложении рекомендуется создавать его на уровне корневого компонента","type":"text"},{"text":" ","type":"text"},{"text":"и передавать по цепочке в иерархии компонентов.","type":"text"}],"type":"paragraph"},{"name":"See Also","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackComponent"}],"type":"paragraph"}]},{"name":"See Also","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/ComponentContext"}],"type":"paragraph"}]},{"type":"aside","name":"See Also","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/ru.hh.Levi