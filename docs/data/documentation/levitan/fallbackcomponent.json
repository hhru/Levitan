{"hierarchy":{"paths":[["doc:\/\/ru.hh.Levitan\/documentation\/Levitan"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FallbackComponent","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"Component","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/Component","preciseIdentifier":"s:7Levitan9ComponentP","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"UIView","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/Component\/UIView","preciseIdentifier":"s:7Levitan9ComponentP6UIViewQa","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"FallbackComponentView","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackComponentView","preciseIdentifier":"s:7Levitan21FallbackComponentViewP","kind":"typeIdentifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"В UIKit-компонентах данные и UI-представление разделены,","type":"text"},{"text":" ","type":"text"},{"text":"и данный протокол ","type":"text"},{"code":"FallbackComponent","type":"codeVoice"},{"text":" используется для реализации слоя данных,","type":"text"},{"text":" ","type":"text"},{"text":"а для реализации UI-представления используется протокол ","type":"text"},{"code":"FallbackComponentView","type":"codeVoice"},{"text":", например:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/\/ Слой данных UIKit-компонента","struct Foo: FallbackComponent {","","    typealias UIView = FooView","","    let text: String","}","","\/\/\/ UI-представление UIKit-компонента","final class FooView: UIView {","","    private let label = UILabel()","","    override init(frame: CGRect) {","        super.init(frame: frame)","","        setupLabel()","    }","","    required init?(coder: NSCoder) {","        fatalError(\"init(coder:) has not been implemented\")","    }","","    private func setupLabel() {","        addSubview(label)","","        label.snp.makeConstraints { make in","            make.edges.equalToSuperview()","        }","    }","}","","extension FooView: FallbackComponentView {","","    static func sizing(","        for content: Content,","        fitting size: CGSize,","        context: ComponentContext","    ) -> ComponentSizing {","        ComponentSizing(","            width: .fill,","            height: .hug","        )","    }","","    func update(","        with content: Foo,","        context: ComponentContext","    ) {","        label.text = content.text","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Так как определение размеров - это зона ответственности UI-представления,","type":"text"},{"text":" ","type":"text"},{"text":"то метод ","type":"text"},{"code":"sizing(for:fitting:context:)","type":"codeVoice"},{"text":" реализуется именно в нем, а слой данных просто проксирует вызовы.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Любой UIKit-компонент, соответствующий этому протоколу ","type":"text"},{"code":"FallbackComponent","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"так же соответствует протоколу ","type":"text"},{"code":"Component","type":"codeVoice"},{"text":", поэтому так же может быть использован и в UIKit, и в SwiftUI.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"В качестве UI-представления для SwiftUI используется отдельная сущность - ","type":"text"},{"code":"FallbackComponentBody","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"которая является универсальной реализацией протокола ","type":"text"},{"code":"UIViewRepresentable","type":"codeVoice"},{"text":" для всех UIKit-компонентов.","type":"text"}]},{"type":"aside","style":"note","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackComponentView"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/FallbackComponentBody"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/ComponentContext"}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/Component"}],"type":"paragraph"}]}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Протокол для UIKit-компонентов."}],"kind":"symbol","metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FallbackComponent","kind":"identifier"}],"roleHeading":"Protocol","externalID":"s:7Levitan17FallbackComponentP","symbolKind":"protocol","title":"FallbackComponent","navigatorTitle":[{"kind":"identifier","text":"FallbackComponent"}],"role":"symbol","modules":[{"name":"Levitan"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/levitan\/fallbackcomponent"]}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/ru.hh.Levitan\/documentation\/Levitan\/Component","doc:\/\/ru.hh.Levitan\/SQ","doc:\/\/ru.hh.Levitan\/7SwiftUI4ViewP"]},{"type":"in